{
  "name": "@ariesfish/pi-goal",
  "version": "0.2.0",
  "type": "module",
  "description": "Autonomous experiment loop for pi — run, measure, keep or discard. Inspired by karpathy/autoresearch.",
  "keywords": [
    "pi-package",
    "pi",
    "pi-extension",
    "goal",
    "experiment",
    "optimization",
    "benchmark",
    "coding-agent"
  ],
  "license": "MIT",
  "author": "ariesfish<zzlyldy@gmail.com>",
  "homepage": "https://github.com/ariesfish/pi-goal#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ariesfish/pi-goal.git"
  },
  "bugs": {
    "url": "https://github.com/ariesfish/pi-goal/issues"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.28.2",
  "pi": {
    "extensions": [
      "./extensions"
    ],
    "skills": [
      "./skills"
    ]
  },
  "files": [
    "extensions",
    "skills",
    "assets",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "package.json"
  ],
  "scripts": {
    "test": "node --experimental-strip-types --test \"tests/**/*.test.mjs\"",
    "test:finalize": "bash tests/scripts/finalize_test.sh"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "@sinclair/typebox": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "^0.75.0",
    "@earendil-works/pi-coding-agent": "^0.75.0",
    "@earendil-works/pi-tui": "^0.75.0",
    "@sinclair/typebox": "^0.34.41",
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3"
  }
}
